# Server Configuration
PORT=3000
NODE_ENV=development

# Database Settings (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bitwise_learning
DB_USER=postgres
DB_PASSWORD=postgres

# Authentication
JWT_SECRET=super_secret_jwt_sign_key_999!
API_ENCRYPTION_KEY=default_secret_32_bytes_long_key_!

# Firebase Google Sign-In Credentials
FIREBASE_PROJECT_ID=bitwise-learning-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@bitwise-learning.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQDh...\n-----END PRIVATE KEY-----\n"

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Application Version Control
APP_LATEST_VERSION=1.0.0
APP_MIN_REQUIRED_VERSION=1.0.0
APP_DOWNLOAD_URL=https://play.google.com/store/apps/details?id=com.bitwise.learning
